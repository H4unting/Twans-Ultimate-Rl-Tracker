{
  "name": "twans-tracker-bridge",
  "version": "1.1.0",
  "description": "System tray app — Twans Auto-Log for RL and Valorant stats",
  "main": "src/main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "postbuild": "node scripts/copy-exe.cjs"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.twans.rl-tracker-bridge",
    "productName": "Twans Auto-Log",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../scripts",
        "to": "bridge-scripts",
        "filter": [
          "*.mjs"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Twans Auto-Log.exe"
    }
  }
}
