{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "Twans Val Auto-Log",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.169.0",
    "author": "Twans Ultimate Tracker",
    "icon": "icon.png",
    "icon_gray": "icon.png",
    "description": "Sends Valorant match results to Twans Ultimate Tracker — no API keys needed."
  },
  "permissions": ["GameInfo"],
  "data": {
    "game_targeting": { "type": "dedicated", "game_ids": [21640] },
    "game_events": [21640],
    "start_window": "background",
    "windows": {
      "background": {
        "file": "background.html",
        "is_background_page": true,
        "transparent": true,
        "size": { "width": 1, "height": 1 }
      }
    },
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": { "game_ids": [21640] },
        "start_minimized": true
      }
    ]
  }
}
