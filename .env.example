# Local bridge secrets — copy to .env in repo root (gitignored) or set in Windows user environment.
# Prefer env vars over storing keys in config/grind-config.json.

# Henrik Dev API key (Valorant match history) — https://api.henrikdev.xyz/dashboard
HENRIK_API_KEY=HDEV-your-key-here

# Optional legacy Riot dev key (not used for Val match history)
# RIOT_API_KEY=

# Valorant account (alternative to grind-config.json)
# RIOT_ID=Name#TAG
# RIOT_REGION=na

# Rocket League display name (alternative to grind-config.json / RLNAME in .bat)
# RL_PLAYER_NAME=YourName

# Bridge auth token — auto-generated each launch if unset; set to rotate explicitly
# BRIDGE_AUTH_TOKEN=

# Optional token for Overwolf extension POSTs to /valorant/overwolf-*
# OVERWOLF_BRIDGE_TOKEN=

# Tracker root override (portable installs)
# TWANS_TRACKER_ROOT=

# Windows code signing (release builds only — set on CI or release machine, never commit secrets)
# CSC_LINK=path-or-base64-to-pfx
# CSC_KEY_PASSWORD=your-cert-password
# See docs/DESKTOP-INSTALL.md
