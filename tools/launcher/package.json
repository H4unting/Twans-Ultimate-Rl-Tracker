{
  "name": "twans-tracker-bridge",
  "version": "1.3.0",
  "description": "Desktop launcher — Twans Ultimate Tracker for RL and Valorant",
  "author": "Anthony",
  "main": "src/main.cjs",
  "private": true,
  "scripts": {
    "generate-icon": "node scripts/generate-icon.mjs",
    "prebuild": "node scripts/generate-icon.mjs",
    "start": "electron .",
    "build": "electron-builder --win portable nsis",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis",
    "postbuild": "node scripts/copy-exe.cjs"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.twans.rl-tracker-bridge",
    "productName": "Twans Ultimate Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../../scripts",
        "to": "bridge-scripts",
        "filter": [
          "*.mjs"
        ]
      },
      {
        "from": "../..",
        "to": "tracker-app",
        "filter": [
          "index.html",
          "js/**/*",
          "css/**/*",
          "assets/**/*",
          "public/**/*",
          "legal/**/*",
          "config/**/*",
          "vendor/**/*",
          "integrations/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Twans Ultimate Tracker.exe"
    },
    "nsis": {
      "artifactName": "TwansUltimateTrackerSetup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
